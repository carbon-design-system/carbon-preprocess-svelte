{
  "name": "carbon-preprocess-svelte",
  "version": "0.11.36",
  "license": "Apache-2.0",
  "description": "A zero-dependency library providing Svelte preprocessors and build plugins for the Carbon Design System",
  "author": "Eric Liu (https://github.com/metonym)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "index:components": "bun scripts/index-components.ts && biome check --write --unsafe src/component-index.ts",
    "prebuild": "BUILD=true bun run index:components",
    "build": "bun scripts/build.ts",
    "build:prune-package": "bunx culls",
    "test": "bun test --parallel",
    "test:e2e": "bun tests/test-e2e.ts",
    "test:e2e:update": "UPDATE_SNAPSHOTS=true bun tests/test-e2e.ts",
    "test:fixtures:update": "UPDATE_FIXTURES=true bun test tests/optimize-css-fixtures.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome check --write --unsafe .",
    "upgrade-examples": "bun scripts/upgrade-examples.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "^1.3.14",
    "@types/jest": "^30.0.0",
    "carbon-components-svelte": "0.109.0",
    "culls": "^0.2.0",
    "estree-walker": "^2.0.2",
    "magic-string": "^0.30.17",
    "postcss": "^8.5.15",
    "postcss-discard-empty": "^8.0.0",
    "svelte": "^5.56.2",
    "typescript": "^7.0.1-rc",
    "vite": "^8.0.16",
    "webpack": "^5.107.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carbon-design-system/carbon-preprocess-svelte.git"
  },
  "homepage": "https://github.com/carbon-design-system/carbon-preprocess-svelte",
  "bugs": "https://github.com/carbon-design-system/carbon-preprocess-svelte/issues",
  "keywords": [
    "carbon",
    "carbon design system",
    "svelte",
    "preprocessor",
    "plugin",
    "zero-dependency",
    "optimize imports",
    "optimize CSS",
    "vite",
    "rollup",
    "webpack"
  ],
  "files": [
    "dist"
  ],
  "maintainers": [
    "Eric Liu (https://github.com/metonym)"
  ]
}
